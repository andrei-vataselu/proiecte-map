<Application x:Class="MusicPlayer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#0D1117"/>
        <SolidColorBrush x:Key="Bg2Brush" Color="#161B22"/>
        <SolidColorBrush x:Key="Bg3Brush" Color="#21262D"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#30363D"/>
        <SolidColorBrush x:Key="TextBrush" Color="#E6EDF3"/>
        <SolidColorBrush x:Key="Text2Brush" Color="#8B949E"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#3B82F6"/>
        <SolidColorBrush x:Key="OrangeBrush" Color="#FFA657"/>
        <SolidColorBrush x:Key="GreenBrush" Color="#3FB950"/>
        <SolidColorBrush x:Key="PurpleBrush" Color="#BC8CFF"/>
    </Application.Resources>
</Application>
